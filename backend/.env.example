# =============================================
#   EnemFlow — Variáveis de Ambiente
#   Copie este arquivo para .env e preencha
# =============================================

# === SERVIDOR ===
PORT=3000
NODE_ENV=development

# === BANCO DE DADOS ===
# Local:
MONGO_URI=mongodb://localhost:27017/enemflow
# Atlas (produção):
# MONGO_URI=mongodb+srv://<usuario>:<senha>@cluster.mongodb.net/enemflow?retryWrites=true&w=majority

# === JWT (preencher depois, quando implementar auth) ===
JWT_SECRET=sua_chave_secreta_aqui_minimo_32_caracteres
JWT_EXPIRES_IN=7d

# === IA LOCAL (Ollama) ===
OLLAMA_URL=http://localhost:11434

# === CORS ===
FRONTEND_URL=http://localhost:5500
